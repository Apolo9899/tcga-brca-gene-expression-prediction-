// ─── Nextflow configuration ───────────────────────────────────────────────────
manifest {
    name        = 'tcga-brca-gene-expression-wsi'
    description = 'Preprocessing pipeline: TCGA-BRCA WSI tiling + RNA-seq TPM normalization + embedding precomputation'
    version     = '1.0.0'
}

// Default process resources
process {
    withLabel: 'download' {
        cpus   = 4
        memory = '8 GB'
        time   = '12h'
    }
    withLabel: 'cpu' {
        cpus   = 8
        memory = '32 GB'
        time   = '6h'
    }
    withLabel: 'gpu' {
        cpus        = 4
        memory      = '32 GB'
        time        = '12h'
        accelerator = 1
    }
}

// Execution profiles
profiles {
    local {
        process.executor = 'local'
        executor {
            cpus   = 16
            memory = '64 GB'
        }
    }

    slurm {
        process.executor = 'slurm'
        process {
            withLabel: 'gpu' {
                clusterOptions = '--gres=gpu:1 --partition=gpu'
            }
        }
    }
}

// Cache intermediate results (avoid recomputation if pipeline is re-run)
process.cache = 'lenient'

// Pipeline execution report
report {
    enabled = true
    file    = "${params.outdir}/reports/pipeline_report.html"
}
